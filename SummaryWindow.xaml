<<Window
    x:Class="CleanAimTracker.SummaryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Session Summary"
    Width="700"
    Height="900"
    Background="#1A1A1A">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Background="#1A1A1A" Orientation="Vertical" VerticalAlignment="Top" Spacing="20">

            <TextBlock Text="Session Summary"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <!-- Two-column grid -->
            <Grid ColumnSpacing="20" RowSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Duration -->
                <Border Grid.Column="0" Background="#252525" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Duration" Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="DurationText" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Total Samples -->
                <Border Grid.Column="1" Background="#252525" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Total Samples" Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SamplesText" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Flicks -->
                <Border Grid.Column="0" Grid.Row="1" Background="#252525" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Flicks" Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="FlicksText" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Micro Adjustments -->
                <Border Grid.Column="1" Grid.Row="1" Background="#252525" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Micro Adjustments" Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="MicroAdjustText" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Overshoots -->
                <Border Grid.Column="0" Grid.Row="2" Background="#252525" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Overshoots" Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="OvershootText" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Undershoots -->
                <Border Grid.Column="1" Grid.Row="2" Background="#252525" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Undershoots" Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="UndershootText" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Average Velocity -->
                <Border Grid.Column="0" Grid.Row="3" Background="#252525" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Average Velocity" Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="AvgVelocityText" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Peak Velocity -->
                <Border Grid.Column="1" Grid.Row="3" Background="#252525" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Peak Velocity" Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="PeakVelocityText" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Jitter -->
                <Border Grid.Column="0" Grid.Row="4" Background="#252525" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Jitter" Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="JitterText" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Smoothness -->
                <Border Grid.Column="1" Grid.Row="4" Background="#252525" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Smoothness" Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SmoothnessText" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Movement Consistency -->
                <Border Grid.Column="0" Grid.Row="5" Background="#252525" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Movement Consistency" Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ConsistencyText" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Correction Sharpness -->
                <Border Grid.Column="1" Grid.Row="5" Background="#252525" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Correction Sharpness" Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SharpnessText" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Overall Quality (full width) -->
                <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="6" Background="#2A2A2A" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Overall Quality" Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="OverallQualityText" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

            </Grid>
        </StackPanel>
    </ScrollViewer>
    </Window>



