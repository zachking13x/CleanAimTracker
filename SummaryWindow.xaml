<Window
    x:Class="CleanAimTracker.SummaryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CleanAimTracker"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Session Summary">

    <Grid Background="#1E1E1E" Padding="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Session Summary"
                   FontSize="28"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 20"
                   Foreground="White"/>

        <!-- Card Grid -->
        <Grid Grid.Row="1" ColumnSpacing="20" RowSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Time -->
            <Border Grid.Row="0" Grid.Column="0"
                    Background="#2A2A2A"
                    CornerRadius="12"
                    Padding="12"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Time"
                               FontSize="14"
                               Foreground="#CCCCCC"/>
                    <TextBlock x:Name="TimeText"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Distance -->
            <Border Grid.Row="0" Grid.Column="1"
                    Background="#2A2A2A"
                    CornerRadius="12"
                    Padding="12"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Distance"
                               FontSize="14"
                               Foreground="#CCCCCC"/>
                    <TextBlock x:Name="DistanceText"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Avg Speed -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="#2A2A2A"
                    CornerRadius="12"
                    Padding="12"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Avg Speed"
                               FontSize="14"
                               Foreground="#CCCCCC"/>
                    <TextBlock x:Name="AvgSpeedText"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Peak Speed -->
            <Border Grid.Row="1" Grid.Column="1"
                    Background="#2A2A2A"
                    CornerRadius="12"
                    Padding="12"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Peak Speed"
                               FontSize="14"
                               Foreground="#CCCCCC"/>
                    <TextBlock x:Name="PeakSpeedText"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Flicks -->
            <Border Grid.Row="2" Grid.Column="0"
                    Background="#2A2A2A"
                    CornerRadius="12"
                    Padding="12"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Flicks"
                               FontSize="14"
                               Foreground="#CCCCCC"/>
                    <TextBlock x:Name="FlicksText"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Smoothness -->
            <Border Grid.Row="2" Grid.Column="1"
                    Background="#2A2A2A"
                    CornerRadius="12"
                    Padding="12"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Smoothness"
                               FontSize="14"
                               Foreground="#CCCCCC"/>
                    <TextBlock x:Name="SmoothnessText"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Sharpness -->
            <Border Grid.Row="3" Grid.Column="0"
                    Background="#2A2A2A"
                    CornerRadius="12"
                    Padding="12"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Correction Sharpness"
                               FontSize="14"
                               Foreground="#CCCCCC"/>
                    <TextBlock x:Name="SharpnessText"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Consistency -->
            <Border Grid.Row="3" Grid.Column="1"
                    Background="#2A2A2A"
                    CornerRadius="12"
                    Padding="12"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Movement Consistency"
                               FontSize="14"
                               Foreground="#CCCCCC"/>
                    <TextBlock x:Name="ConsistencyText"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Overall Quality -->
            <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    Background="#2A2A2A"
                    CornerRadius="12"
                    Padding="12"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Overall Quality"
                               FontSize="14"
                               Foreground="#CCCCCC"/>
                    <TextBlock x:Name="QualityText"
                               FontSize="26"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="White"/>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>

</Window>
                   