<Window
    x:Class="CleanAimTracker.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#1E1E1E" Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Clean Aim Tracker"
                   FontSize="28"
                   Foreground="White"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- Stats -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="8">

            <TextBlock x:Name="MovementText"
                       Text="ΔX: 0   ΔY: 0"
                       FontSize="20"
                       Foreground="LightGray"
                       HorizontalAlignment="Center"/>

            <TextBlock x:Name="DistanceText"
                       Text="Total Distance: 0"
                       FontSize="20"
                       Foreground="LightGray"
                       HorizontalAlignment="Center"/>

            <TextBlock x:Name="TimeText"
                       Text="Session Time: 00:00"
                       FontSize="18"
                       Foreground="Gray"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Controls -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="10"
                    Margin="0,20,0,0">

            <Button x:Name="StartButton"
                    Content="Start"
                    Width="80"
                    Click="StartButton_Click"/>

            <Button x:Name="StopButton"
                    Content="Stop"
                    Width="80"
                    Click="StopButton_Click"/>

            <Button x:Name="ResetButton"
                    Content="Reset"
                    Width="80"
                    Click="ResetButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
