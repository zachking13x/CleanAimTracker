<Window
    x:Class="CleanAimTracker.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="#1E1E1E" Margin="20">

            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="LastDeltaText"
                       Text="Last Δ: 0, 0"
                        Foreground="White"
                        FontSize="16"
                        Margin="0,0,0,10"/>


            <!-- Title -->
            <TextBlock Text="Clean Aim Tracker"
                       FontSize="32"
                       Foreground="White"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Stats Section -->
            <StackPanel Grid.Row="1"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Center">

                <StackPanel.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Margin" Value="0,0,0,10" />
                    </Style>
                </StackPanel.Resources>

                <!-- Movement -->
                <TextBlock x:Name="MovementText" Text="ΔX: 0   ΔY: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="DistanceText" Text="Total Distance: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TimeText" Text="Session Time: 00:00" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="Cm360Text" Text="cm/360: --" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>

                <!-- Velocity -->
                <TextBlock x:Name="VelocityText" Text="Speed: 0 cm/s" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="PeakVelocityText" Text="Peak: 0 cm/s" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="AverageVelocityText" Text="Average: 0 cm/s" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="CurrentVelocityText"
                           Text="Current: 0 cm/s"
                           Foreground="White"
                           FontSize="16"
                           Margin="0,5,0,0"/>

                <!-- Flicks -->
                <TextBlock x:Name="FlickCountText" Text="Flicks: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="SmallFlicksText" Text="Small Flicks: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="LargeFlicksText" Text="Large Flicks: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>

                <!-- Jitter -->
                <TextBlock x:Name="JitterText" Text="Jitter: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>

                <!-- Smoothness -->
                <TextBlock x:Name="SmoothnessText" Text="Smoothness: 100" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="CorrectionSharpnessText" Text="Correction Sharpness: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="MovementConsistencyText" Text="Movement Consistency: 100" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="OverallQualityText" Text="Overall Quality: 100" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>

                <!-- Density / Idle -->
                <TextBlock x:Name="MovementDensityText" Text="Density: 0 eps" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="IdleTimeText" Text="Idle: 0 s" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="IdleTimeSinceMoveText" Text="Idle Time: 0.0 s" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="IdlePercentageText" Text="Idle %: 0%" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>

                <!-- Angles -->
                <TextBlock x:Name="AngleText" Text="Angle: 0°" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="AngleStabilityText" Text="Stability: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="AngleChangeText" Text="Angle Change: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="RawAngleDeltaText" Text="Raw Delta: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TrueAngleDeltaText" Text="True Delta: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="PreviousAngleText" Text="Prev Angle: 0°" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>

                <!-- Distance Per Event -->
                <TextBlock x:Name="DistancePerEventText" Text="Dist/Event: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="AverageDistancePerEventText" Text="Avg Dist/Event: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="PeakDistancePerEventText" Text="Peak Dist/Event: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>

                <!-- Velocity Change -->
                <TextBlock x:Name="PeakVelocityChangeText" Text="Peak Vel Change: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>

                <!-- Movement Count -->
                <TextBlock x:Name="MovementCountPerSecondText" Text="MPS: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="RollingDensityText" Text="Rolling Density: 0 eps" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="IdleBurstText" Text="Idle Bursts: 0" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>

                <!-- Acceleration -->
                <TextBlock x:Name="AccelerationText" Text="Accel: 0 cm/s²" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="PeakAccelerationText" Text="Peak Accel: 0 cm/s²" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="AverageAccelerationText" Text="Avg Accel: 0 cm/s²" FontSize="20" Foreground="LightGray" HorizontalAlignment="Center"/>

                <!-- Sensitivity + DPI Inputs -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,0">

                    <TextBox x:Name="SensitivityInput"
                             Width="120"
                             Height="32"
                             TextAlignment="Center"
                             Margin="0,0,10,0"
                             ToolTip="Sensitivity"
                             Text=""/>

                    <TextBox x:Name="DpiInput"
                             Width="120"
                             Height="32"
                             TextAlignment="Center"
                             ToolTip="DPI"
                             Text=""/>
                </StackPanel>

            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0">

                <Button x:Name="StartButton" Content="Start Tracking" Width="150" Height="40" Click="StartButton_Click" Margin="0,0,20,0"/>
                <Button x:Name="StopButton" Content="Stop Tracking" Width="150" Height="40" Click="StopButton_Click" Margin="0,0,20,0"/>
                <Button x:Name="ResetButton" Content="Reset" Width="150" Height="40" Click="ResetButton_Click" Margin="0,0,20,0"/>
                <Button x:Name="SummaryButton" Content="Summary" Width="150" Height="40" Click="OpenSummary_Click" Margin="0,0,20,0"/>

                <Button Content="Session History"
                        Width="150"
                        Height="40"
                        Click="OpenSessionHistory_Click"/>

            </StackPanel>
             
        </Grid>
    </ScrollViewer>
</Window>