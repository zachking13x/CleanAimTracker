<Window
    x:Class="CleanAimTracker.SessionHistoryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:CleanAimTracker.Models"
    mc:Ignorable="d"
    Title="Session History">

    <Grid Padding="20">
        <StackPanel Spacing="12">

            <TextBlock Text="Session History"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <ListView x:Name="SessionsList"
                      Height="350"
                      SelectionMode="Single"
                      IsItemClickEnabled="True"
                      ItemClick="SessionsList_ItemClick">
                        

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:SessionSummary">
                        <StackPanel Orientation="Horizontal" Spacing="16">

                            <!-- Date -->
                            <TextBlock Text="{x:Bind SessionEnd}"
                                       Width="200"/>

                            <!-- Duration -->
                            <TextBlock Text="{x:Bind Duration}"
                                       Width="120"/>

                            <!-- Samples -->
                            <TextBlock Text="{x:Bind TotalSamples}"
                                       Width="100"/>

                            <!-- Flicks -->
                            <TextBlock Text="{x:Bind FlickCount}"
                                       Width="80"/>

                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>

        </StackPanel>
    </Grid>
</Window>
