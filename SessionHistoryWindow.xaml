<Window
    x:Class="CleanAimTracker.SessionHistoryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:CleanAimTracker.Models"
    mc:Ignorable="d"
    Title="Session History">

    <Grid Padding="20">
        <StackPanel>
            <StackPanel.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Margin" Value="0,0,0,12"/>
                </Style>
            </StackPanel.Resources>

            <TextBlock Text="Session History"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <ListView x:Name="SessionsList"
                      Height="350"
                      SelectionMode="Single"
                      SelectionChanged="SessionsList_SelectionChanged">
                         

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="0,0,16,0"/>
                                </Style>
                            </StackPanel.Resources>

                            <!-- Date -->
                            <TextBlock Text="{Binding SessionEnd}"
                                       Width="200"/>

                            <!-- Duration -->
                            <TextBlock Text="{Binding Duration}"
                                       Width="120"/>

                            <!-- Samples -->
                            <TextBlock Text="{Binding TotalSamples}"
                                       Width="100"/>

                            <!-- Flicks -->
                            <TextBlock Text="{Binding FlickCount}"
                                       Width="80"/>

                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>

        </StackPanel>
    </Grid>
</Window>
